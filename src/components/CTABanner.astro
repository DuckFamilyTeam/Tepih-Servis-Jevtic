---
---

<section class="cta-banner" aria-label="Poziv na akciju — zakažite pranje">
  <div class="cta-banner__bg" aria-hidden="true">
    <img
      src="https://images.unsplash.com/photo-1585771724684-38269d6639fd?w=1600&q=75&auto=format&fit=crop"
      alt=""
      loading="lazy"
      decoding="async"
      width="1600"
      height="600"
      class="cta-banner__img"
    />
    <div class="cta-banner__overlay"></div>
  </div>

  <div class="cta-banner__content container reveal">
    <p class="eyebrow" style="color: var(--gold-light);">Zakažite danas</p>
    <h2 class="cta-banner__title">
      Čist tepih — čist dom.<br />
      <em>Prepustite nam brigu.</em>
    </h2>
    <p class="cta-banner__subtitle">
      Besplatno preuzimanje i dostava · 350 din/m² · Od 2009. godine
    </p>
    <div class="cta-banner__actions">
      <a href="tel:+381600425222" class="btn btn--gold cta-banner__btn">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/>
        </svg>
        +381 60 042 5222
      </a>
      <a href="tel:+381638966351" class="btn btn--outline">
        +381 63 896 6351
      </a>
      <a href="https://www.instagram.com/autopranje_tepihservisjevtic" target="_blank" rel="noopener noreferrer" class="btn btn--outline cta-banner__instagram">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
        </svg>
        Instagram
      </a>
    </div>
  </div>
</section>

<style>
.cta-banner {
  position: relative;
  padding: clamp(80px, 12vw, 160px) 0;
  text-align: center;
  overflow: hidden;
}

.cta-banner__bg {
  position: absolute;
  inset: 0;
}

.cta-banner__img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center;
}

.cta-banner__overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(
    135deg,
    rgba(26, 24, 20, 0.88) 0%,
    rgba(46, 42, 36, 0.82) 100%
  );
}

.cta-banner__content {
  position: relative;
  z-index: 1;
}

.cta-banner__title {
  font-size: clamp(2.2rem, 5vw, 4rem);
  color: var(--ivory);
  margin-bottom: 20px;
  font-weight: 300;
}

.cta-banner__title em {
  font-style: italic;
  color: var(--gold-light);
}

.cta-banner__subtitle {
  font-size: 0.85rem;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: rgba(201, 168, 76, 0.7);
  margin-bottom: 44px;
}

.cta-banner__actions {
  display: flex;
  gap: 14px;
  justify-content: center;
  flex-wrap: wrap;
}

.cta-banner__btn {
  padding: 16px 36px;
  font-size: 0.82rem;
}
</style>
