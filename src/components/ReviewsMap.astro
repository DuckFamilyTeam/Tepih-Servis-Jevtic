---
---

<section class="reviews-map section" id="recenzije-mapa" aria-label="Google recenzije i mapa">
  <div class="container">
    <div class="reviews-map__grid">

      <!-- Google Reviews -->
      <div class="reviews-map__reviews reveal">
        <p class="eyebrow">Google recenzije</p>
        <h2>Šta kažu naši klijenti</h2>
        <div class="gold-divider"></div>
        <p class="reviews-map__desc">
          Pročitajte iskustva naših klijenata direktno na Google-u. Više od 15 godina zadovoljnih porodica u Beogradu.
        </p>
        <a
          href="https://share.google/tSbL2qAu7ucf99PEe"
          target="_blank"
          rel="noopener noreferrer"
          class="btn btn--gold reviews-map__btn"
          aria-label="Pogledajte naše Google recenzije"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
            <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
            <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
            <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
          </svg>
          Pročitajte Google recenzije
        </a>

        <!-- Star rating display -->
        <div class="reviews-map__rating">
          <div class="reviews-map__stars" aria-label="Ocena 5 od 5">
            <span>★</span><span>★</span><span>★</span><span>★</span><span>★</span>
          </div>
          <span class="reviews-map__rating-text">5.0 · Google recenzije</span>
        </div>
      </div>

      <!-- Google Map -->
      <div class="reviews-map__map reveal reveal-delay-2">
        <p class="eyebrow">Gde se nalazimo</p>
        <h2>Naša lokacija</h2>
        <div class="gold-divider"></div>
        <div class="reviews-map__map-wrap">
          <iframe
            src="https://www.google.com/maps/embed?pb=!1m17!1m12!1m3!1d2827.0707075369423!2d20.463448715448!3d44.881218099999996!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m2!1m1!2zNDTCsDUyJzUyLjQiTiAyMMKwMjcnNTYuMyJF!5e0!3m2!1ssr!2srs!4v1746720000000!5m2!1ssr!2srs"
            width="600"
            height="400"
            style="border:0;"
            allowfullscreen=""
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="Tepih Servis Jevtić — lokacija na mapi, Borča Beograd"
            aria-label="Google mapa lokacije Tepih Servis Jevtić"
          ></iframe>
        </div>
        <p class="reviews-map__address">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
          </svg>
          Borča, Beograd · Besplatno dolazimo na Vašu adresu
        </p>
      </div>

    </div>
  </div>
</section>

<style>
.reviews-map {
  background: var(--ivory-dark);
}

.reviews-map__grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: clamp(48px, 7vw, 100px);
  align-items: start;
}

.reviews-map__desc {
  margin-bottom: 28px;
  font-size: 0.95rem;
}

.reviews-map__btn {
  margin-bottom: 24px;
  display: inline-flex;
}

.reviews-map__rating {
  display: flex;
  align-items: center;
  gap: 12px;
}

.reviews-map__stars {
  display: flex;
  gap: 2px;
  color: var(--gold);
  font-size: 1.2rem;
}

.reviews-map__rating-text {
  font-family: var(--font-sans);
  font-size: 0.8rem;
  color: var(--text-secondary);
  letter-spacing: 0.05em;
}

/* Map */
.reviews-map__map-wrap {
  border-radius: var(--radius-md);
  overflow: hidden;
  box-shadow: var(--shadow-deep);
  border: 1px solid rgba(201, 168, 76, 0.15);
  margin-bottom: 16px;
}

.reviews-map__map-wrap iframe {
  width: 100%;
  height: 380px;
  display: block;
}

.reviews-map__address {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 0.82rem;
  color: var(--text-secondary);
}

.reviews-map__address svg {
  color: var(--gold);
  flex-shrink: 0;
}

@media (max-width: 900px) {
  .reviews-map__grid {
    grid-template-columns: 1fr;
  }
}
</style>
