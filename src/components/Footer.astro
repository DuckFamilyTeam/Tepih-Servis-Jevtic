---
const currentYear = new Date().getFullYear();

const locations = [
  'Borča', 'Ovča', 'Krnjača', 'Padinska Skela', 'Kovilovo',
  'Zemun', 'Altina', 'Zemun Polje', 'Batajnica', 'Bežanijska Kosa', 'Novi Beograd'
];
---

<footer class="footer" role="contentinfo">
  <div class="footer__top">
    <div class="footer__gold-line" aria-hidden="true"></div>
    <div class="container">
      <div class="footer__grid">
        <!-- Brand col -->
        <div class="footer__brand">
          <div class="footer__logo">
            <img src="/images/logo.png" alt="Tepih Servis Jevtić" class="footer__logo-img" width="160" height="54" loading="lazy" />
          </div>
          <p class="footer__tagline">
            Profesionalno pranje i čišćenje tepiha u Beogradu od 2009. godine. Besplatno preuzimanje i dostava.
          </p>
          <!-- Instagram -->
          <a
            href="https://www.instagram.com/autopranje_tepihservisjevtic"
            target="_blank"
            rel="noopener noreferrer"
            class="footer__social"
            aria-label="Pratite nas na Instagramu"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
            </svg>
            @autopranje_tepihservisjevtic
          </a>
        </div>

        <!-- Contact col -->
        <div class="footer__col">
          <h3 class="footer__heading">Kontakt</h3>
          <ul class="footer__list">
            <li>
              <a href="tel:+381600425222" class="footer__contact-link">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/>
                </svg>
                +381 60 042 5222
              </a>
            </li>
            <li>
              <a href="tel:+381638966351" class="footer__contact-link">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/>
                </svg>
                +381 63 896 6351
              </a>
            </li>
            <li>
              <a href="mailto:autopranje77@gmail.com" class="footer__contact-link">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/>
                </svg>
                autopranje77@gmail.com
              </a>
            </li>
          </ul>

          <div class="footer__price">
            <span class="footer__price-label">Cena pranja</span>
            <span class="footer__price-value">350 din/m²</span>
            <span class="footer__price-note">+ besplatna dostava</span>
          </div>
        </div>

        <!-- Locations col -->
        <div class="footer__col">
          <h3 class="footer__heading">Naše lokacije</h3>
          <ul class="footer__locations">
            {locations.map((loc) => (
              <li>
                <span class="footer__loc-bullet" aria-hidden="true">✦</span>
                {loc}
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="footer__bottom">
    <div class="container footer__bottom-inner">
      <p class="footer__copyright">
        © {currentYear} Tepih Servis Jevtić · Borča, Beograd · Sva prava zadržana
      </p>
      <p class="footer__since">
        <span aria-hidden="true">✦</span> U poslu od 2009. godine
      </p>
    </div>
    <div class="container footer__made-by">
      <p class="footer__made-by-text">Sajt izradio</p>
      <a
        href="https://www.duckfamilyteam.online/"
        target="_blank"
        rel="noopener noreferrer"
        class="footer__made-by-link"
        aria-label="DuckFamilyTeam - Google Ads Marketing"
      >
        <img
          src="/images/duckfamilyteam-logo.png"
          alt="DuckFamilyTeam Google Ads Marketing"
          class="footer__dft-logo"
          width="120"
          height="40"
          loading="lazy"
        />
        <span class="footer__dft-name">DuckFamilyTeam</span>
      </a>
    </div>
  </div>
</footer>

<style>
.footer {
  background: var(--charcoal);
  color: var(--ivory);
}

.footer__top {
  padding: clamp(60px, 8vw, 100px) 0 clamp(48px, 6vw, 80px);
  position: relative;
}

.footer__gold-line {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 1px;
  background: linear-gradient(90deg, transparent, var(--gold), transparent);
}

.footer__grid {
  display: grid;
  grid-template-columns: 1.5fr 1fr 1fr;
  gap: clamp(40px, 5vw, 80px);
}

/* Brand */
.footer__logo {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 20px;
}

.footer__logo-img {
  height: 52px;
  width: auto;
  object-fit: contain;
  filter: brightness(0) invert(1);
  opacity: 0.9;
  margin-bottom: 4px;
}

.footer__tagline {
  font-size: 0.88rem;
  color: rgba(250, 247, 242, 0.55);
  line-height: 1.75;
  margin-bottom: 24px;
}

.footer__social {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  font-size: 0.78rem;
  color: rgba(201, 168, 76, 0.8);
  border: 1px solid rgba(201, 168, 76, 0.2);
  border-radius: var(--radius-sm);
  padding: 10px 16px;
  transition: all var(--transition-fast);
}

.footer__social:hover {
  background: rgba(201, 168, 76, 0.1);
  border-color: rgba(201, 168, 76, 0.4);
  color: var(--gold-light);
}

/* Col headings */
.footer__heading {
  font-family: var(--font-sans);
  font-size: 0.65rem;
  font-weight: 600;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--gold);
  margin-bottom: 20px;
}

/* Contact */
.footer__list {
  display: flex;
  flex-direction: column;
  gap: 10px;
  margin-bottom: 28px;
}

.footer__contact-link {
  display: flex;
  align-items: center;
  gap: 10px;
  font-size: 0.88rem;
  color: rgba(250, 247, 242, 0.7);
  transition: color var(--transition-fast);
}

.footer__contact-link:hover {
  color: var(--gold-light);
}

.footer__price {
  display: flex;
  flex-direction: column;
  gap: 4px;
  padding: 16px;
  background: rgba(201, 168, 76, 0.08);
  border: 1px solid rgba(201, 168, 76, 0.15);
  border-radius: var(--radius-sm);
}

.footer__price-label {
  font-size: 0.65rem;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: rgba(201, 168, 76, 0.6);
}

.footer__price-value {
  font-family: var(--font-serif);
  font-size: 1.6rem;
  color: var(--gold-light);
  line-height: 1;
}

.footer__price-note {
  font-size: 0.72rem;
  color: rgba(250, 247, 242, 0.45);
}

/* Locations */
.footer__locations {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 6px 12px;
}

.footer__locations li {
  display: flex;
  align-items: center;
  gap: 6px;
  font-size: 0.82rem;
  color: rgba(250, 247, 242, 0.55);
}

.footer__loc-bullet {
  color: var(--gold);
  font-size: 0.4rem;
  flex-shrink: 0;
}

/* Bottom */
.footer__bottom {
  border-top: 1px solid rgba(201, 168, 76, 0.1);
  padding: 20px 0;
}

.footer__bottom-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20px;
  flex-wrap: wrap;
}

.footer__copyright {
  font-size: 0.78rem;
  color: rgba(250, 247, 242, 0.35);
}

.footer__since {
  font-size: 0.78rem;
  color: rgba(201, 168, 76, 0.5);
  display: flex;
  align-items: center;
  gap: 8px;
}

@media (max-width: 900px) {
  .footer__grid {
    grid-template-columns: 1fr 1fr;
  }

  .footer__brand {
    grid-column: 1 / -1;
  }
}

@media (max-width: 560px) {
  .footer__grid {
    grid-template-columns: 1fr;
  }

  .footer__bottom-inner {
    flex-direction: column;
    text-align: center;
  }
}

/* DuckFamilyTeam credit */
.footer__made-by {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10px;
  padding: 12px 0 16px;
  border-top: 1px solid rgba(255, 255, 255, 0.06);
}

.footer__made-by-text {
  font-size: 0.75rem;
  color: rgba(250, 247, 242, 0.35);
}

.footer__made-by-link {
  display: flex;
  align-items: center;
  gap: 8px;
  text-decoration: none;
  transition: opacity var(--transition-fast);
}

.footer__made-by-link:hover {
  opacity: 0.8;
}

.footer__dft-logo {
  height: 32px;
  width: auto;
  object-fit: contain;
}

.footer__dft-name {
  font-size: 0.78rem;
  font-weight: 600;
  color: rgba(250, 247, 242, 0.6);
  letter-spacing: 0.03em;
}
</style>
