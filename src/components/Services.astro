---
const services = [
  {
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 3c1.66 0 3 1.34 3 3s-1.34 3-3 3-3-1.34-3-3 1.34-3 3-3zm0 14.2c-2.5 0-4.71-1.28-6-3.22.03-1.99 4-3.08 6-3.08 1.99 0 5.97 1.09 6 3.08-1.29 1.94-3.5 3.22-6 3.22z"/></svg>`,
    title: 'Pranje tepiha i staza',
    desc: 'Klasično profesionalno pranje svih vrsta tepiha i staza. Koristimo proverene metode i sredstva koja su bezbedna za vlakna i boje.',
    details: ['Sve vrste tepiha', 'Ručno i mašinsko pranje tepiha', 'Staze i predprostirači', 'Bezbedan za decu i kućne ljubimce'],
  },
  {
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/></svg>`,
    title: 'Dubinsko pranje tepiha',
    desc: 'Intenzivno dubinsko čišćenje koje uklanja tvrdokorne mrlje, alergene, grinje i bakterije iz dubine vlakana tepiha.',
    details: ['Uklanjanje tvrdokornih mrlja', 'Eliminacija alergena i grinja', 'Dezinfekcija vlakana', 'Osvežavanje boja'],
  },
  {
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg>`,
    title: 'Suvo čišćenje tepiha',
    desc: 'Metoda suvogsčišćenja pogodna za osetljive tepise koji ne smeju biti mokri. Brzo sušenje i odličan rezultat.',
    details: ['Za osetljive materijale', 'Brzo sušenje', 'Svileni i antički tepihi', 'Bez rizika od skupljanja'],
  },
];
---

<section class="services section" id="usluge" aria-labelledby="services-title">
  <!-- Background texture -->
  <div class="services__bg" aria-hidden="true"></div>

  <div class="container">
    <div class="section-heading reveal">
      <p class="eyebrow">Naše usluge</p>
      <h2 id="services-title">Stručnost koja se vidi</h2>
      <div class="gold-divider gold-divider--center"></div>
      <p>Svaki tepih tretiramo individualno. Koristimo profesionalnu opremu i sredstva za pranje koja su bezbedna za ljude i životinje.</p>
    </div>

    <div class="services__grid">
      {services.map((service, i) => (
        <article class={`card-luxury services__card reveal reveal-delay-${i + 1}`} aria-labelledby={`service-title-${i}`}>
          <div class="services__card-icon" aria-hidden="true" set:html={service.icon} />
          <h3 class="services__card-title" id={`service-title-${i}`}>{service.title}</h3>
          <p class="services__card-desc">{service.desc}</p>
          <ul class="services__card-list" aria-label={`Detalji: ${service.title}`}>
            {service.details.map((detail) => (
              <li class="services__card-item">
                <span class="services__card-bullet" aria-hidden="true">✦</span>
                {detail}
              </li>
            ))}
          </ul>
        </article>
      ))}
    </div>

    <!-- Price CTA -->
    <div class="services__price-cta reveal">
      <div class="services__price-box">
        <div class="services__price-left">
          <p class="eyebrow" style="margin-bottom: 8px;">Transparentna cena</p>
          <h3>Cena pranja tepiha</h3>
          <p>Fiksna cena, bez skrivenih troškova. Besplatno dolazimo po tepih i vraćamo ga na Vašu adresu.</p>
        </div>
        <div class="services__price-right">
          <div class="services__price-tag">
            <span class="services__price-amount">350</span>
            <span class="services__price-unit">din/m²</span>
          </div>
          <p class="services__price-note">+ besplatno preuzimanje i dostava</p>
          <a href="tel:+381600425222" class="btn btn--gold">Zakažite pranje</a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
.services {
  background: var(--ivory);
  position: relative;
  overflow: hidden;
}

.services__bg {
  position: absolute;
  top: -100px;
  right: -200px;
  width: 600px;
  height: 600px;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(201, 168, 76, 0.06) 0%, transparent 70%);
  pointer-events: none;
}

.services__grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 28px;
  margin-bottom: 60px;
}

.services__card {
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.services__card-icon {
  width: 52px;
  height: 52px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--gold-subtle);
  border: 1px solid rgba(201, 168, 76, 0.2);
  border-radius: var(--radius-sm);
  color: var(--gold);
  flex-shrink: 0;
}

.services__card-title {
  font-size: 1.3rem;
  font-weight: 500;
  color: var(--charcoal);
}

.services__card-desc {
  font-size: 0.92rem;
  line-height: 1.75;
  color: var(--text-secondary);
  flex: 1;
}

.services__card-list {
  display: flex;
  flex-direction: column;
  gap: 8px;
  margin-top: 4px;
  border-top: 1px solid var(--ivory-mid);
  padding-top: 16px;
}

.services__card-item {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 0.82rem;
  color: var(--text-secondary);
  font-family: var(--font-sans);
}

.services__card-bullet {
  color: var(--gold);
  font-size: 0.5rem;
  flex-shrink: 0;
}

/* Price CTA */
.services__price-box {
  background: linear-gradient(135deg, var(--charcoal) 0%, var(--charcoal-soft) 100%);
  border-radius: var(--radius-lg);
  padding: clamp(36px, 5vw, 60px);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 40px;
  position: relative;
  overflow: hidden;
}

.services__price-box::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 1px;
  background: linear-gradient(90deg, transparent, var(--gold), transparent);
}

.services__price-box::after {
  content: '✦';
  position: absolute;
  right: 40%;
  top: 50%;
  transform: translate(50%, -50%);
  font-size: 200px;
  color: rgba(201, 168, 76, 0.03);
  pointer-events: none;
  line-height: 1;
}

.services__price-left {
  flex: 1;
}

.services__price-left h3 {
  font-size: clamp(1.6rem, 3vw, 2.2rem);
  color: var(--ivory);
  margin-bottom: 12px;
}

.services__price-left p {
  color: rgba(250, 247, 242, 0.65);
  font-size: 0.95rem;
}

.services__price-right {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12px;
  flex-shrink: 0;
}

.services__price-tag {
  display: flex;
  align-items: flex-start;
  gap: 6px;
}

.services__price-amount {
  font-family: var(--font-serif);
  font-size: 4rem;
  font-weight: 300;
  color: var(--gold-light);
  line-height: 1;
}

.services__price-unit {
  font-family: var(--font-sans);
  font-size: 0.9rem;
  font-weight: 500;
  color: var(--gold);
  margin-top: 10px;
  letter-spacing: 0.05em;
}

.services__price-note {
  font-size: 0.75rem;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: rgba(201, 168, 76, 0.7);
  text-align: center;
}

@media (max-width: 900px) {
  .services__grid {
    grid-template-columns: 1fr;
    gap: 20px;
  }

  .services__price-box {
    flex-direction: column;
    text-align: center;
  }

  .services__price-left {
    text-align: center;
  }
}
</style>
