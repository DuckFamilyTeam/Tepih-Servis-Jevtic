---
const stats = [
  { num: '2009', label: 'Osnivanje firme' },
  { num: '15+', label: 'Godina iskustva' },
  { num: '1000+', label: 'Zadovoljnih klijenata' },
  { num: '11', label: 'Opština Beograda' },
];
---

<section class="about section section--ivory-mid" id="o-nama" aria-labelledby="about-title">
  <div class="container">
    <div class="about__layout">
      <!-- Image col -->
      <div class="about__image-col reveal">
        <div class="about__image-wrap">
          <img
            src="/images/zasto-mi.jpg"
            alt="Zašto izabrati Tepih Servis Jevtić — profesionalno pranje tepiha"
            width="600"
            height="720"
            loading="lazy"
            decoding="async"
            class="about__image"
          />
          <!-- Gold badge overlay -->
          <div class="about__badge" aria-label="Od 2009. godine">
            <span class="about__badge-year">2009</span>
            <span class="about__badge-text">U poslu od</span>
          </div>
        </div>
        <!-- Decorative gold line -->
        <div class="about__deco-line" aria-hidden="true"></div>
      </div>

      <!-- Text col -->
      <div class="about__text-col">
        <div class="reveal">
          <p class="eyebrow">Ko smo mi</p>
          <h2 id="about-title">Iskustvo i kvalitet<br /><em>od 2009. godine</em></h2>
          <div class="gold-divider"></div>
        </div>

        <p class="about__lead reveal reveal-delay-1">
          Tepih Servis Jevtić je porodična firma sa sedištem u Borči koja se već više od 15 godina bavi profesionalnim pranjem i čišćenjem tepiha na teritoriji Beograda.
        </p>

        <p class="about__text reveal reveal-delay-2">
          Tokom godina izgradili smo reputaciju na temeljima pouzdanosti, stručnosti i izuzetne usluge. Svaki tepih tretiramo s posebnom pažnjom, koristeći profesionalnu opremu i sredstva koja su bezbedna za Vašu porodicu i kućne ljubimce.
        </p>

        <div class="about__features reveal reveal-delay-3">
          <div class="about__feature">
            <span class="about__feature-icon" aria-hidden="true">✦</span>
            <div>
              <h4>Besplatno preuzimanje i dostava</h4>
              <p>Dolazimo po Vaš tepih i vraćamo ga čist na Vašu adresu.</p>
            </div>
          </div>
          <div class="about__feature">
            <span class="about__feature-icon" aria-hidden="true">✦</span>
            <div>
              <h4>Profesionalna oprema</h4>
              <p>Koristimo industrijsku opremu za pranje i sušenje.</p>
            </div>
          </div>
          <div class="about__feature">
            <span class="about__feature-icon" aria-hidden="true">✦</span>
            <div>
              <h4>Bezbedna sredstva</h4>
              <p>Sredstva za pranje su bezbedna za decu, alergičare i kućne ljubimce.</p>
            </div>
          </div>
        </div>

        <div class="about__cta reveal reveal-delay-4">
          <a href="tel:+381600425222" class="btn btn--gold">Pozovite: +381 60 042 5222</a>
          <a href="tel:+381638966351" class="btn btn--outline-dark">+381 63 896 6351</a>
        </div>
      </div>
    </div>

    <!-- Stats row -->
    <div class="about__stats" role="list" aria-label="Statistike firme">
      {stats.map((stat, i) => (
        <div class={`about__stat reveal reveal-delay-${i + 1}`} role="listitem">
          <span class="about__stat-num">{stat.num}</span>
          <span class="about__stat-label">{stat.label}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
.about__layout {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: clamp(48px, 7vw, 100px);
  align-items: center;
  margin-bottom: clamp(60px, 8vw, 100px);
}

/* Image col */
.about__image-col {
  position: relative;
}

.about__image-wrap {
  position: relative;
  border-radius: var(--radius-lg);
  overflow: hidden;
  aspect-ratio: 5/6;
}

.about__image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform var(--transition-slow);
}

.about__image-wrap:hover .about__image {
  transform: scale(1.04);
}

.about__badge {
  position: absolute;
  bottom: 32px;
  right: -20px;
  background: linear-gradient(135deg, var(--gold) 0%, var(--gold-dark) 100%);
  color: var(--ivory);
  padding: 20px 28px;
  border-radius: var(--radius-md);
  box-shadow: 0 8px 32px rgba(201, 168, 76, 0.4);
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.about__badge-year {
  font-family: var(--font-serif);
  font-size: 2rem;
  font-weight: 600;
  line-height: 1;
}

.about__badge-text {
  font-size: 0.65rem;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  opacity: 0.85;
  margin-top: 4px;
}

.about__deco-line {
  position: absolute;
  top: 40px;
  left: -20px;
  width: 3px;
  height: 120px;
  background: linear-gradient(to bottom, var(--gold), transparent);
  border-radius: 2px;
}

/* Text col */
.about__text-col h2 {
  margin-bottom: 0;
}

.about__text-col h2 em {
  font-style: italic;
  color: var(--gold-dark);
}

.about__lead {
  font-family: var(--font-serif);
  font-size: clamp(1.05rem, 1.8vw, 1.2rem);
  color: var(--charcoal);
  line-height: 1.7;
  margin-bottom: 20px;
}

.about__text {
  font-size: 0.95rem;
  color: var(--text-secondary);
  line-height: 1.85;
  margin-bottom: 32px;
}

.about__features {
  display: flex;
  flex-direction: column;
  gap: 20px;
  margin-bottom: 36px;
}

.about__feature {
  display: flex;
  gap: 16px;
  align-items: flex-start;
}

.about__feature-icon {
  color: var(--gold);
  font-size: 0.6rem;
  margin-top: 6px;
  flex-shrink: 0;
}

.about__feature h4 {
  font-size: 0.95rem;
  font-weight: 500;
  color: var(--charcoal);
  margin-bottom: 4px;
  font-family: var(--font-sans);
}

.about__feature p {
  font-size: 0.85rem;
  color: var(--text-secondary);
  line-height: 1.6;
}

.about__cta {
  display: flex;
  gap: 14px;
  flex-wrap: wrap;
}

/* Stats */
.about__stats {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 2px;
  background: rgba(201, 168, 76, 0.15);
  border-radius: var(--radius-md);
  overflow: hidden;
}

.about__stat {
  background: var(--ivory-dark);
  padding: 36px 28px;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  gap: 8px;
  transition: background var(--transition-fast);
}

.about__stat:hover {
  background: var(--champagne);
}

.about__stat-num {
  font-family: var(--font-serif);
  font-size: clamp(2rem, 3.5vw, 2.8rem);
  font-weight: 400;
  color: var(--gold-dark);
  line-height: 1;
}

.about__stat-label {
  font-family: var(--font-sans);
  font-size: 0.72rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--text-secondary);
}

@media (max-width: 900px) {
  .about__layout {
    grid-template-columns: 1fr;
  }

  .about__badge {
    right: 16px;
    bottom: 16px;
  }

  .about__stats {
    grid-template-columns: repeat(2, 1fr);
  }
}
</style>
